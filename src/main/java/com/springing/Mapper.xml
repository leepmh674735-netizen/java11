<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace는 연결할 Mapper 인터페이스의 전체 경로(패키지 포함)를 적습니다 -->
<mapper namespace="com.winter.yubin.review.ReviewMapper">

    <!-- 1. 조회 (Select) -->
    <!-- id는 인터페이스의 메서드명과 일치해야 하며, resultType은 결과 데이터를 담을 DTO 경로입니다 -->
    <select id="getList" resultType="com.winter.yubin.review.ReviewDTO" parameterType="com.winter.yubin.review.ReviewDTO">
        SELECT * FROM REVIEW
        WHERE NUM > 0
        ORDER BY NUM DESC
    </select>

    <!-- 2. 삽입 (Insert) -->
    <!-- #{필드명}을 사용하면 DTO의 getter를 호출하여 값을 바인딩합니다 -->
    <insert id="setCreate" parameterType="com.winter.yubin.review.ReviewDTO">
        INSERT INTO REVIEW (NUM, WRITER, CONTENT, REGDATE)
        VALUES (REVIEW_SEQ.NEXTVAL, #{writer}, #{content}, CURRENT_TIMESTAMP)
    </insert>

    <!-- 3. 수정 (Update) -->
    <update id="setUpdate" parameterType="com.winter.yubin.review.ReviewDTO">
        UPDATE REVIEW 
        SET CONTENT = #{content}
        WHERE NUM = #{num}
    </update>

    <!-- 4. 삭제 (Delete) -->
    <delete id="setDelete" parameterType="com.winter.yubin.review.ReviewDTO">
        DELETE FROM REVIEW WHERE NUM = #{num}
    </delete>

</mapper>